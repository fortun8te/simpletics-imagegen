{%- comment -%}
  10-sticky-cta.liquid — NanoXtreme ARTHRITIS LP (cloned from broad-angle).
  Hand-edited arthritis variant. Unchanged from broad-angle (no angle-specific copy).
{%- endcomment -%}
<div class="nx-sticky-cta" id="nx-sticky-cta" role="region" aria-label="Buy now" aria-hidden="true">
  <div class="nx-sticky-cta-inner">
    <div class="nx-sticky-cta-info">
      <span class="nx-sticky-cta-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span class="nx-sticky-cta-rating">4.44 &middot; 1,033 reviews</span>
      <span class="nx-sticky-cta-product">NanoXtreme Pain Relief Cream</span>
    </div>
    <a href="https://www.nanoxtreme.com/products/nanoxtreme-tube" class="nx-sticky-cta-btn">Get Relief <span aria-hidden="true">&rarr;</span></a>
    <button type="button" class="nx-sticky-cta-close" id="nx-sticky-cta-close" aria-label="Dismiss">&times;</button>
  </div>
</div>
<style>
  .nx-sticky-cta{position:fixed;left:0;right:0;bottom:0;z-index:9999;background:#ffffff;border-top:1px solid #e7e4dd;box-shadow:0 -6px 24px rgba(0,0,0,0.12);font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;transform:translateY(110%);transition:transform .4s cubic-bezier(.22,1,.36,1);will-change:transform;}
  .nx-sticky-cta[data-visible="true"]{transform:translateY(0);}
  .nx-sticky-cta-inner{display:flex;align-items:center;gap:12px;max-width:720px;margin:0 auto;padding:10px 14px;padding-bottom:calc(10px + env(safe-area-inset-bottom,0px));box-sizing:border-box;}
  .nx-sticky-cta-info{flex:1 1 auto;min-width:0;line-height:1.3;}
  .nx-sticky-cta-stars{color:#f5a623;font-size:13px;letter-spacing:1px;vertical-align:middle;}
  .nx-sticky-cta-rating{font-size:12px;font-weight:600;color:#6a6478;vertical-align:middle;margin-left:4px;white-space:nowrap;}
  .nx-sticky-cta-product{display:block;font-size:14px;font-weight:700;color:#2e2a39;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .nx-sticky-cta-btn{flex:0 0 auto;display:inline-block;text-align:center;padding:14px 20px;background:#111111;color:#ffffff;text-decoration:none;font-size:15px;font-weight:800;letter-spacing:.02em;text-transform:uppercase;border-radius:999px;box-shadow:0 4px 14px rgba(0,0,0,0.22);transition:transform .15s ease,filter .15s ease;}
  .nx-sticky-cta-btn:active{transform:translateY(1px);}
  .nx-sticky-cta-btn:hover{filter:brightness(0.96);}
  .nx-sticky-cta-close{flex:0 0 auto;background:transparent;border:0;color:#6a6478;font-size:22px;line-height:1;width:28px;height:28px;padding:0;cursor:pointer;opacity:.55;}
  .nx-sticky-cta-close:hover{opacity:1;}
  @media (prefers-reduced-motion: reduce){.nx-sticky-cta{transition:none;}}
</style>
<script>
  (function(){
    var bar=document.getElementById('nx-sticky-cta');
    var close=document.getElementById('nx-sticky-cta-close');
    if(!bar)return;
    var dismissed=false;
    try{if(sessionStorage.getItem('nx-sticky-cta-dismissed')==='1')dismissed=true;}catch(e){}
    function y(){return window.pageYOffset||document.documentElement.scrollTop||document.body.scrollTop||0;}
    function nearBox(){var b=document.getElementById('nx-buybox');if(!b)return false;var r=b.getBoundingClientRect();return r.top<(window.innerHeight*0.9)&&r.bottom>0;}
    function update(){
      if(dismissed){bar.removeAttribute('data-visible');return;}
      if(y()>250&&!nearBox()){bar.setAttribute('data-visible','true');bar.setAttribute('aria-hidden','false');}
      else{bar.removeAttribute('data-visible');bar.setAttribute('aria-hidden','true');}
    }
    if(close){close.addEventListener('click',function(){dismissed=true;bar.removeAttribute('data-visible');bar.setAttribute('aria-hidden','true');try{sessionStorage.setItem('nx-sticky-cta-dismissed','1');}catch(e){}});}
    window.addEventListener('scroll',update,{passive:true});
    window.addEventListener('touchmove',update,{passive:true});
    window.addEventListener('resize',update,{passive:true});
    window.addEventListener('load',update);
    update();
  })();
</script>
