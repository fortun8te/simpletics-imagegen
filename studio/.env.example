# NEUEGEN Studio — environment (copy to .env; .env is gitignored)

# ── LLM provider (design agent, planner, copy) ──────────────────────────────────────────────
# Any OpenAI-compatible endpoint works. Default = DeepSeek.
DEEPSEEK_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash

# LM Studio (local model) — start the LM Studio server, then:
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=qwen2.5-7b-instruct          # whatever model id LM Studio shows
# LLM_API_KEY=                           # leave empty — no auth header is sent

# Ollama:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=gemma2:9b

# ── TrendTrack (competitor ad ingestion — 1 credit per returned row) ────────────────────────
TRENDTRACK_API_KEY=sk_tt_...

# ── codex engine (image generation + vision extraction) ────────────────────────────────────
# CODEX_CLI=/Applications/Codex.app/Contents/Resources/codex   # override binary path
# CONCURRENCY=2          # parallel generation jobs
# COOLDOWN_MIN=30        # rate-limit cooldown minutes
# GRACE_SECONDS=10       # cancel-grace window before a job spawns

# ── Vision endpoint (optional) ────────────────────────────────────────────────
# The LM Studio endpoint. Ornith (ornith-1.0-9b) is the DEFAULT for BOTH vision and reasoning —
# it does both — so you do NOT need a separate vision model. Just load ornith in LM Studio and it
# is used automatically for extraction, image descriptions, the agent's `look` op, AND text.
# VISION_BASE_URL=http://localhost:1234/v1
# VISION_API_KEY=
#
# DO NOT set VISION_MODEL to a specific name unless that EXACT model is the one you keep loaded.
# The effective model is resolved ONLY from what LM Studio reports as LOADED (via /api/v0/models),
# so a stale VISION_MODEL pointing at a downloaded-but-unloaded model (e.g. an old gemma id) is
# IGNORED — this is deliberate: naming an unloaded model would make LM Studio JIT-load a SECOND
# model, causing contention/slowness. Leave VISION_MODEL unset to always use whatever is loaded.
# VISION_MODEL=

# ── OpenCode Zen remote backend — the recommended copy-from-reference upgrade ──
# A hosted OpenAI-compatible gateway (https://opencode.ai/zen) with FREE models. Get a key at
# https://opencode.ai/auth and paste it below. mimo-v2.5-free is VISION-CAPABLE (confirmed) with a
# ~200k context — a big step up from local ornith-9b for READING the ad, which is the copy-fidelity
# bottleneck. Setting these four routes BOTH the extraction (eyes) and the reasoning (brain) to it:
# OPENCODE_ZEN_API_KEY=sk-...
# VISION_BASE_URL=https://opencode.ai/zen/v1
# VISION_MODEL=mimo-v2.5-free
# VISION_API_KEY=${OPENCODE_ZEN_API_KEY}
# LLM_BASE_URL=https://opencode.ai/zen/v1
# LLM_MODEL=mimo-v2.5-free
# LLM_API_KEY=${OPENCODE_ZEN_API_KEY}
#
# First run `node scripts/probe-vision-backends.mjs` once — it confirms the exact image wire-format
# works against Zen and prints latency, so a free-tier rate cap or format quirk surfaces before a
# full sweep. To fall back to local ornith, just comment these out (ornith stays the default).
#
# COPY_IMPROVE_PASSES=10   # self-improve rounds per copy (default is lower for slow local ornith;
#                          # a fast remote model can afford 10+ — see docs/OPENCODE-ZEN-BACKEND.md)

# ── Preferred local model (ornith is the default) ─────────────────────────────
# Detection: the SMALLEST loaded "ornith*" model is auto-preferred (the 9b over a 35b a laptop
# can't load); if ornith isn't loaded, whatever IS loaded is used (never force-load ornith — that
# would spawn a second model). PREFERRED_MODEL can pin an exact id/substring, but it is honored
# ONLY when that id is actually LOADED (a hint at an unloaded model is ignored, never JIT-loaded).
# Nothing loaded → auto-fallback to DeepSeek (reasoning), so nothing ever breaks.
# PREFERRED_MODEL=ornith-1.0-9b

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=8788                     # studio-server.mjs listen port

# ── Image generation (chatgpt-imagegen CLI) ─────────────────────────────────
# CHATGPT_IMAGEGEN=/path/to/chatgpt-imagegen   # override the CLI binary path
# CHATGPT_IMAGEGEN_EFFORT=low                  # low|medium|high — reasoning effort passed through
# CHATGPT_IMAGEGEN_VERBOSITY=low               # low|medium|high — response verbosity passed through
# SSL_CERT_FILE=/etc/ssl/cert.pem              # CA bundle for the CLI's python subprocess (macOS default is auto-detected)
# GEN_TIMEOUT_MS=240000                        # per-generation timeout in ms (default 4 min)

# ── Layout extraction ────────────────────────────────────────────────────────
# SELFCHECK=1                   # force the extraction self-check pass (also: EXTRACT_SELFCHECK)
# EXTRACT_SELFCHECK=1           # alias for SELFCHECK

# ── Job store ────────────────────────────────────────────────────────────────
# FAILED_TTL=45000              # ms a failed job stays visible before pruning (default 45s)

# ── Inspo loop (scripts/design-agent-inspo-loop.mjs) ────────────────────────
# INSPO_DIR=~/Downloads/IMAGE AD INSPO   # folder of reference images the inspo-recreation benchmark reads
