// lib/self-vision.mjs — the agent LOOKS at its own work: render the doc server-side
// and critique the PNG with the configured endpoint's vision (lib/llm.mjs llmVision).
//
// Two render backends, tried in order:
//   1. Headless Chrome/Chromium (real modern CSS: @font-face, corner-shape:squircle,
//      true retina via --force-device-scale-factor) — preferred when installed.
//   2. qlmanage (macOS Quick Look's WebKit thumbnailer, zero deps) — fallback.
//
// Dormant on vision-less endpoints (DeepSeek's API is text-only) — the design agent only
// advertises the "look" op when a probe of llmVision succeeds once per process.

import { spawnSync } from 'node:child_process';
import { writeFileSync, existsSync, mkdirSync, rmSync } from 'node:fs';
import { join, dirname } from 'node:path';
import { fileURLToPath } from 'node:url';
import { platform } from 'node:os';
import { renderDesignHtml, makeImageResolver } from './designstore.mjs';
import { llmVision, codexVisionAllowed } from './llm.mjs';
import { codexSee } from './layout-extract.mjs';
import { pixelDiff, contentSpread } from '../scripts/pixel-diff.mjs';

const STUDIO = dirname(fileURLToPath(import.meta.url), '..');
const TMP = join(dirname(fileURLToPath(import.meta.url)), '..', '.state', 'self-vision');

// --- Chrome/Chromium detection (cached — probed at most once per process) ---------------

const CHROME_CANDIDATES = [
  '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome',
  '/Applications/Chromium.app/Contents/MacOS/Chromium',
  '/Applications/Google Chrome Canary.app/Contents/MacOS/Google Chrome Canary',
];

let _chromePathCache; // undefined = not probed yet, null = probed & not found, string = found

/** Find a usable headless-capable Chrome/Chromium binary. Cached after the first probe. */
function findChrome() {
  if (_chromePathCache !== undefined) return _chromePathCache;
  for (const p of CHROME_CANDIDATES) {
    if (existsSync(p)) { _chromePathCache = p; return p; }
  }
  // non-mac fallback: look on PATH
  if (platform() !== 'darwin') {
    for (const cmd of ['google-chrome', 'google-chrome-stable', 'chromium', 'chromium-browser']) {
      try {
        const r = spawnSync('which', [cmd], { timeout: 5_000 });
        if (r.status === 0) {
          const p = String(r.stdout || '').trim();
          if (p) { _chromePathCache = p; return p; }
        }
      } catch { /* keep probing */ }
    }
  }
  _chromePathCache = null;
  return null;
}

// --- render backends ----------------------------------------------------------------------

/** Try rendering htmlPath → pngPath via headless Chrome. Returns true on verified success. */
function renderWithChrome(chromePath, htmlPath, pngPath, size, doc) {
  try {
    rmSync(pngPath, { force: true });
    // Translate the qlmanage-style `size` (roughly a square thumbnail edge) into a
    // window that matches the comp's REAL aspect ratio, so non-square formats (e.g. a
    // 1080x1920 story) render at correct proportions instead of being squished/cropped —
    // qlmanage's `-s` only ever produced a square-ish thumbnail regardless of aspect.
    const cw = Number(doc?.canvas?.w) > 0 ? Number(doc.canvas.w) : 1080;
    const ch = Number(doc?.canvas?.h) > 0 ? Number(doc.canvas.h) : 1080;
    // WINDOW = the EXACT canvas CSS px. The old code sized the window to canvas×(size/longEdge)
    // while renderDesignHtml draws the comp at NATIVE canvas px — Chrome captured only the
    // top-left window-sized region (a 1080×1920 story lost >50% of its width; found via the
    // copy-fidelity harness: "blank"/cropped renders + inflated overflow). Capture 1:1.
    const winW = Math.max(1, Math.round(cw));
    const winH = Math.max(1, Math.round(ch));
    const args = [
      '--headless',
      '--disable-gpu',
      `--screenshot=${pngPath}`,
      `--window-size=${winW},${winH}`,
      '--force-device-scale-factor=1',
      '--hide-scrollbars',
      '--default-background-color=00000000',
      '--no-sandbox',
      `file://${htmlPath}`,
    ];
    const r = spawnSync(chromePath, args, { timeout: 20_000 });
    if (r.status !== 0 || !existsSync(pngPath)) {
      console.error(`[self-vision] chrome render failed (status=${r.status}${r.error ? `, err=${r.error.message}` : ''}), falling back to qlmanage`);
      return false;
    }
    console.error('[self-vision] rendered via headless Chrome');
    return true;
  } catch (err) {
    console.error(`[self-vision] chrome render threw (${err?.message || err}), falling back to qlmanage`);
    return false;
  }
}

/** Try rendering htmlPath → outDir/<basename>.png via qlmanage. Returns true on verified success. */
function renderWithQlmanage(htmlPath, pngPath, outDir, size) {
  try {
    rmSync(pngPath, { force: true });
    const r = spawnSync('qlmanage', ['-t', '-s', String(size), '-o', outDir, htmlPath], { timeout: 20_000 });
    if (r.status !== 0 || !existsSync(pngPath)) {
      console.error(`[self-vision] qlmanage render failed (status=${r.status})`);
      return false;
    }
    console.error('[self-vision] rendered via qlmanage');
    return true;
  } catch (err) {
    console.error(`[self-vision] qlmanage render threw (${err?.message || err})`);
    return false;
  }
}

/**
 * Render a doc to a PNG on disk. Prefers headless Chrome (real @font-face, corner-shape:
 * squircle, true 3x retina) when installed; falls back to qlmanage (old WebKit, zero deps)
 * otherwise. Same return contract either way: the PNG path on success, or null on failure.
 */
export function renderCompPng(doc, { resolveImage = null, size = 900 } = {}) {
  try {
    mkdirSync(TMP, { recursive: true });
    const html = renderDesignHtml(doc, resolveImage || ((s) => s));
    const htmlPath = join(TMP, `${doc.id || 'comp'}.html`);
    writeFileSync(htmlPath, html);
    const pngPath = `${htmlPath}.png`;

    const chromePath = findChrome();
    if (chromePath && renderWithChrome(chromePath, htmlPath, pngPath, size, doc)) {
      return pngPath;
    }
    if (renderWithQlmanage(htmlPath, pngPath, TMP, size)) {
      return pngPath;
    }
    return null;
  } catch { return null; }
}

const CRITIQUE_PROMPT = `You are a senior art director reviewing this ad render. In ≤4 short bullet points, list the most important CONCRETE problems (clipped/overlapping text, illegible contrast, misalignment, dead space, wrong hierarchy). If it looks production-ready say exactly "ready". Plain text.`;

/** Edit-mode critique: judge whether a SPECIFIC edit landed AND still looks right — not "is this
 *  a good ad" (that's the generate-mode CRITIQUE_PROMPT). Tighter scope = fewer off-topic "fixes"
 *  that undo the user's intent. Falls back to the general prompt when no goal is supplied. */
const EDIT_CRITIQUE_PROMPT = (goal) => `You are a senior art director looking at an ad render right AFTER this edit was applied:
"${String(goal || '').slice(0, 200)}"
Judge TWO things you can SEE: (1) did the edit actually land (is the change visible/correct)?
(2) did it introduce any CONCRETE visible problem (clipped/overlapping text, illegible contrast,
knocked-out alignment, text off-canvas)? In ≤3 short bullets list ONLY real, visible problems to
fix — do NOT invent unrelated redesign suggestions. If the edit landed and nothing looks broken,
say exactly "ready". Plain text.`;

/**
 * Look at the doc and return { ok, critique, error }. Uses the configured vision endpoint;
 * never throws. Pass `goal` to switch to the tighter EDIT critique (did this edit land + look
 * right) instead of the open-ended "is this a good ad" review — backward-compatible when omitted.
 */
export async function lookAtComp(doc, { resolveImage = null, goal = null } = {}) {
  const png = renderCompPng(doc, { resolveImage });
  if (!png) return { ok: false, critique: null, error: 'could not render the comp (qlmanage unavailable?)' };
  const prompt = goal ? EDIT_CRITIQUE_PROMPT(goal) : CRITIQUE_PROMPT;
  const r = await llmVision(prompt, png, { purpose: 'self-vision', maxTokens: 1200 });
  if (r.ok) return { ok: true, critique: r.text.trim().slice(0, 600), error: null };
  // vision-less endpoint (DeepSeek) → codex CLI fallback (default-on; usage is minimal)
  if (r.noVision && codexVisionAllowed()) {
    const c = await codexSee(prompt, png);
    if (c.ok) return { ok: true, critique: c.text.slice(0, 600), error: null };
    return { ok: false, critique: null, error: c.error };
  }
  return { ok: false, critique: null, error: r.error, noVision: r.noVision };
}

// FIX 4: return STRUCTURED corrections the design agent can act on — a list of
// {layer, problem, fix} — not just prose. Vision-endpoint driven; JSON with a prose fallback.
const COMPARE_PROMPT = (refNote) => `You are comparing two images side by side. ${refNote}
The FIRST image is a GENERATED render to be evaluated. The SECOND image is the REFERENCE (target).
Compare them carefully and report every CONCRETE visual difference the render has vs the reference.

For each issue name the LAYER (e.g. "headline", "CTA button", "background", "product image"),
the PROBLEM (what is wrong: position, size, color, missing/extra piece, weak contrast, wrong
hierarchy, font mismatch, alignment), and a specific FIX.

The FIX MUST carry a CONCRETE, MACHINE-APPLICABLE value wherever possible — the design agent applies
these automatically, so vague fixes are wasted:
  • COLOR problems → give the exact target #hex (e.g. "recolor to #0a0a0a", "set text to #ffffff").
  • POSITION problems → give a DIRECTION + PERCENT (e.g. "move up 8%", "nudge right 5%", "shift down 12%").
  • SIZE problems → give a SCALE (e.g. "enlarge to 1.5x", "shrink 20%", "scale to 2x").
  • FONT problems → give the specific font weight/family mismatch (e.g. "should be 800 not 600").
Prefer one concrete value per fix. Do NOT flag copy/text wording differences — the copy is intentionally different.

Be a STRICT judge. Actively hunt for defects the render has that the reference does not — text
that overflows/clips off the edge, oversized or undersized type, overlapping lines, missing UI
chrome (header bar, avatar, follow button, action row), weak contrast (gray where the reference is
white), wrong margins/alignment, wrong font weight or family. Anchor the score to this rubric and do NOT
inflate it just because the background color or copy matches:
  95-100 = indistinguishable from the reference, pixel-tight.
  80-94  = same layout, minor size/spacing/color slips.
  60-79  = right idea but clearly off — oversized/clipped text, weak contrast, or 1-2 missing pieces.
  40-59  = major structure wrong or missing (no header/avatar/action row, text bleeding off-canvas).
  0-39   = does not read as the same screen.

Reply with ONLY this JSON, no prose:
{"score": <0..100 fidelity per the rubric above>,
 "match": <true only if score >= 90>,
 "corrections": [{"layer":"<name>","problem":"<what's wrong>","fix":"<what to do>"}]}
List at most 5 corrections, most important first. If it truly matches (score >= 90), return
{"match": true, "corrections": []}.`;

// COPY-REFERENCE self-check variant (Fable's 026-escalation fix #3): unlike the generic compare
// above, when checking a COPY of a reference the TEXT CONTENT is the whole point — a render that
// swapped the reference's real copy for hallucinated/generic text (e.g. "OURS/THEIRS" headers
// replacing "Premium Silk/Satin", or a dropped eyebrow/"vs" chip/CTA) must be flagged and FIXED,
// not shrugged off as "intentionally different". Corrections whose problem is specifically a TEXT
// CONTENT mismatch are tagged `textFix:true` so the caller can let them bypass the copy-lock.
const COPY_TEXT_COMPARE_PROMPT = (refNote) => `You are checking a COPY of a reference ad for TEXT FIDELITY. ${refNote}
The FIRST image is the render (copy). The SECOND image is the original reference.
This render is supposed to reproduce the reference's actual words — list any text visible in the
reference that is MISSING or DIFFERENT in the render, verbatim where possible (headline, eyebrow,
body copy, badges/chips like "vs", CTA button label, labels). Also flag the usual visual deltas
(position, size, color, missing chrome) same as a normal compare.

For every correction whose problem is a TEXT CONTENT mismatch (wrong words, missing text, invented
text not in the reference), set "textFix": true and give the fix as the EXACT reference text to use
instead (e.g. "set text to \"Premium Silk\""). For non-text corrections omit "textFix" (or set false).

Reply with ONLY this JSON, no prose:
{"score": <0..100 fidelity>,
 "match": <true only if score >= 90>,
 "corrections": [{"layer":"<name>","problem":"<what's wrong>","fix":"<what to do>","textFix":<true|false>}]}
List at most 6 corrections, most important first (text mismatches first). If it truly matches,
return {"match": true, "corrections": []}.`;

/** Pull the {score, match, corrections[]} object out of a (possibly prose-wrapped) vision reply.
 *  Returns { score:number|null, match, corrections:[{layer,problem,fix}] } — never throws.
 *  `score` is the vision judge's own 0..100 estimate when it supplied one, else null (the caller
 *  then derives a score from the correction count). */
function parseCorrections(text) {
  const s = String(text || '');
  let obj = null;
  const m = s.match(/\{[\s\S]*"corrections"[\s\S]*\}/);
  if (m) { try { obj = JSON.parse(m[0]); } catch { obj = null; } }
  if (!obj) { try { obj = JSON.parse(s); } catch { obj = null; } }
  const corrections = Array.isArray(obj?.corrections) ? obj.corrections
    .map((c) => ({
      layer: String(c?.layer || '').slice(0, 60),
      problem: String(c?.problem || '').slice(0, 200),
      fix: String(c?.fix || '').slice(0, 200),
      ...(c?.textFix === true ? { textFix: true } : {}),
    }))
    .filter((c) => c.problem || c.fix)
    .slice(0, 6) : [];
  const match = obj?.match === true || (obj && corrections.length === 0);
  const rawScore = Number(obj?.score);
  const score = Number.isFinite(rawScore) ? Math.max(0, Math.min(100, rawScore)) : null;
  return { score, match: !!match, corrections };
}

// ── fidelity scoring (self-improvement loop) ─────────────────────────────────────────────────
// A single 0..100 number the loop can trend and threshold. Blends TWO independent signals so
// neither dominates: the vision JUDGE (semantic — "does this read as the same ad?") and the
// PIXEL DIFF (structural — "are the light/dark masses in the same places?"). The vision judge is
// the stronger signal (it understands hierarchy/layout intent), so it carries most of the weight;
// the pixel diff anchors it to something objective and un-gameable.
const VISION_WEIGHT = 0.7;
const PIXEL_WEIGHT = 0.3;

/** Derive a vision-side 0..100 from a compare result: prefer the judge's own score, else map the
 *  correction count (each unaddressed correction ≈ −14, a clean match ≈ 96). */
function visionScoreOf({ score, match, corrections }) {
  if (typeof score === 'number') return score;
  if (match && (!corrections || !corrections.length)) return 96;
  const n = Array.isArray(corrections) ? corrections.length : 0;
  return Math.max(20, 92 - n * 14);
}

/** Blend the vision judge score with the objective pixel-diff score. When the pixel diff is
 *  unavailable (undecodable ref, missing render) the vision score stands alone. */
function blendFidelity(visionScore, pixelResult) {
  if (!pixelResult || !pixelResult.ok) return Math.round(visionScore * 10) / 10;
  return Math.round((VISION_WEIGHT * visionScore + PIXEL_WEIGHT * pixelResult.score) * 10) / 10;
}

/**
 * Render `doc` and score how faithfully it matches `referencePath` on a 0..100 scale, combining
 * the vision judge with the objective pixel diff (scripts/pixel-diff.mjs). Returns
 * { ok, score, vision, pixel, match, corrections, notes, error } — never throws. This is the
 * primary signal the self-improvement loop trends across iterations and thresholds on.
 */
export async function scoreFidelity(doc, referencePath, { resolveImage = null } = {}) {
  const png = renderCompPng(doc, { resolveImage });
  if (!png) {
    return { ok: false, score: 0, vision: null, pixel: null, match: false, corrections: [], notes: null, png: null, error: 'could not render the comp' };
  }
  const cmp = await compareToReference(doc, referencePath, { resolveImage, _png: png });
  const pixel = pixelDiff(png, referencePath);
  let visionScore = cmp.ok ? visionScoreOf(cmp) : (pixel.ok ? pixel.score : 0);
  let score = cmp.ok ? blendFidelity(visionScore, pixel) : (pixel.ok ? pixel.score : 0);

  // BLANK-RENDER GUARD: a near-empty render (all-black placeholder, missing base image, no visible
  // overlays) trivially "matches" a dark reference on both the pixel grid AND a lenient vision
  // judge — inflating fidelity to ~100 on a comp that shows NOTHING. Detect it structurally: if the
  // render carries far less luminance content than the reference, it can't be a faithful copy, so
  // hard-cap the score by the content ratio. This keeps the loop honest — it will keep iterating
  // to add the missing content instead of falsely PASSing on an empty canvas.
  const refSpread = contentSpread(referencePath);
  const renderSpread = contentSpread(png);
  let blank = false;
  if (refSpread != null && renderSpread != null && refSpread > 0.02) {
    const ratio = renderSpread / refSpread;               // 1 = as much content as the ref, 0 = blank
    if (ratio < 0.5) {                                     // render has <50% of the reference's content
      const cap = Math.round(Math.max(0, Math.min(1, ratio)) * 100 * 10) / 10; // proportional ceiling
      if (cap < score) { score = cap; blank = true; }
      visionScore = Math.min(visionScore, cap);
    }
  }

  return {
    ok: cmp.ok || pixel.ok,
    score,
    vision: cmp.ok ? Math.round(visionScore * 10) / 10 : null,
    pixel: pixel.ok ? pixel.score : null,
    blank,
    match: cmp.match && !blank,
    corrections: cmp.corrections || [],
    notes: blank ? `render is near-blank (${Math.round((renderSpread / (refSpread || 1)) * 100)}% of reference content)${cmp.notes ? ' · ' + cmp.notes : ''}` : (cmp.notes || null),
    png,
    error: cmp.ok ? null : (pixel.ok ? null : (cmp.error || pixel.error)),
  };
}

/** Render prose bullets from structured corrections (compat for callers reading `notes`). */
function correctionsToProse(match, corrections) {
  if (match && !corrections.length) return 'close match';
  return corrections.map((c) => `• ${c.layer ? c.layer + ': ' : ''}${c.problem}${c.fix ? ' → ' + c.fix : ''}`).join('\n').slice(0, 600);
}

/**
 * Second-pass reference check: render the comp, then ask vision to compare it against the
 * reference image before finalizing. Returns STRUCTURED corrections the design agent can act on:
 * { ok, match, corrections:[{layer,problem,fix}], notes, error }. `notes` is a prose rendering of
 * the same corrections for callers that want a string. Vision-endpoint driven; never throws.
 */
export async function compareToReference(doc, referencePath, { resolveImage = null, _png = null, checkText = false } = {}) {
  const png = _png || renderCompPng(doc, { resolveImage });
  if (!png) return { ok: false, score: null, match: false, corrections: [], notes: null, error: 'could not render the comp' };
  // COPY self-check (checkText:true) uses the text-diffing variant — the whole point of a copy
  // is reproducing the reference's real words, so text mismatches must surface as corrections
  // instead of being waved off as "the copy is intentionally different".
  const prompt = (checkText ? COPY_TEXT_COMPARE_PROMPT : COMPARE_PROMPT)('The reference image is the SECOND image sent to you. Compare the FIRST image (the render) against the SECOND image (the reference). Judge how faithfully the render reproduces the reference.');
  // CRITICAL FIX: send BOTH images — the render (first) and the reference (second).
  // Previously only the render was sent and the model was asked to compare against a reference
  // it never saw, making the vision score a self-assessment rather than a genuine comparison.
  const { existsSync } = await import('node:fs');
  const refPath = existsSync(referencePath) ? referencePath : null;
  const extraImages = refPath ? [refPath] : [];
  const r = await llmVision(prompt, png, { purpose: 'ref-compare', maxTokens: 1200, json: true, extraImages });
  if (r.ok) {
    const { score, match, corrections } = parseCorrections(r.text);
    return { ok: true, score, match, corrections, notes: correctionsToProse(match, corrections), error: null };
  }
  if (r.noVision && codexVisionAllowed()) {
    const c = await codexSee(prompt, png);
    if (c.ok) {
      const { score, match, corrections } = parseCorrections(c.text);
      return { ok: true, score, match, corrections, notes: correctionsToProse(match, corrections), error: null };
    }
    return { ok: false, score: null, match: false, corrections: [], notes: null, error: c.error };
  }
  return { ok: false, score: null, match: false, corrections: [], notes: null, error: r.error };
}

// ── EXTRACT-AND-COMPARE (iterative extraction loop support) ──────────────────────────────────────
// The extraction loop in design-agent.mjs needs to:
// 1. Render the current extraction state
// 2. Compare it against the reference
// 3. Return structured corrections the agent can act on
//
// `extractAndCompare` wraps the render-compare pipeline into a single call that the iterative
// extraction loop can call repeatedly. It builds a renderable doc from the extraction layers,
// renders it to PNG, and runs compareToReference. Returns:
//   { ok, score, match, corrections:[{layer,problem,fix}], png, error }
//
// `correctionToOp` converts a single vision correction into a deterministic design-agent op
// that can be applied without an LLM call. Returns an op object or null when the correction
// is too ambiguous to automate.

/**
 * Render an extraction's current state and compare it against the reference. This is the
 * core primitive for the iterative extraction loop: after each extraction pass, the loop
 * calls this to get a fidelity score and structured corrections.
 *
 * @param {object} extractionResult - The raw extraction result from extractLayout
 *   { layers, canvas, background, backgroundIsPhoto, archetype }
 * @param {string} referencePath - Path to the original reference image
 * @param {object} opts - { resolveImage? }
 * @returns { ok, score, match, corrections:[{layer,problem,fix}], png, error }
 */
export async function extractAndCompare(extractionResult, referencePath, { resolveImage = null } = {}) {
  if (!extractionResult || !extractionResult.layers || !extractionResult.canvas) {
    return { ok: false, score: 0, match: false, corrections: [], png: null, error: 'extractionResult missing layers or canvas' };
  }
  try {
    const { layers, canvas, background, backgroundIsPhoto } = extractionResult;

    // Build a minimal renderable doc from the extraction (same as layout-extract's self-check)
    const { buildDocFromSkeleton } = await import('./layout-extract.mjs').catch(() => ({}));
    let doc;
    if (typeof buildDocFromSkeleton === 'function') {
      const built = buildDocFromSkeleton(layers, canvas, { background, backgroundIsPhoto, referencePath });
      doc = built.doc;
    } else {
      // Fallback: build the doc inline (mirrors layout-extract's buildDocFromSkeleton)
      const REF_SENTINEL = '__extract_ref__';
      const base = [];
      if (backgroundIsPhoto && referencePath) {
        base.push({
          id: 'ext-base-photo', type: 'image', role: 'base', name: 'Reference photo',
          src: REF_SENTINEL, fit: 'cover',
          box: { x: 0, y: 0, w: canvas.w, h: canvas.h }, style: {},
        });
      } else if (background && typeof background === 'object' && background.from && background.to) {
        base.push({
          id: 'ext-base-grad', type: 'shape', role: 'base', name: 'Background',
          box: { x: 0, y: 0, w: canvas.w, h: canvas.h },
          style: { background: `linear-gradient(${Number(background.angle) || 180}deg, ${background.from}, ${background.to})`, opacity: 1 },
        });
      } else if (typeof background === 'string' && /^#[0-9a-fA-F]{3,8}$/.test(background)) {
        base.push({
          id: 'ext-base-solid', type: 'shape', role: 'base', name: 'Background',
          box: { x: 0, y: 0, w: canvas.w, h: canvas.h },
          style: { background, opacity: 1 },
        });
      }
      doc = {
        id: `extract-compare-${Date.now().toString(36)}`,
        name: 'Extraction compare',
        canvas: { w: canvas.w, h: canvas.h },
        layers: [...base, ...(Array.isArray(layers) ? layers : [])],
      };
    }

    // Render the doc to PNG
    const png = renderCompPng(doc, { resolveImage });
    if (!png) return { ok: false, score: 0, match: false, corrections: [], png: null, error: 'could not render the extraction' };

    // Compare against the reference
    const cmp = await compareToReference(doc, referencePath, { resolveImage, _png: png });
    if (!cmp.ok) {
      return { ok: false, score: 0, match: false, corrections: [], png, error: cmp.error };
    }

    return {
      ok: true,
      score: cmp.score ?? 0,
      match: cmp.match,
      corrections: cmp.corrections || [],
      png,
      error: null,
    };
  } catch (e) {
    return { ok: false, score: 0, match: false, corrections: [], png: null, error: e?.message || String(e) };
  }
}

/**
 * Convert a single vision correction into a deterministic design-agent op. This lets the
 * iterative extraction loop apply corrections WITHOUT an LLM call — purely from the structured
 * {layer, problem, fix} data the vision compare returned.
 *
 * Supported correction patterns:
 * - Color fixes: "#hex" in the fix text → setStyle with the target color
 * - Position fixes: "move up/down/left/right N%" → move op with computed delta
 * - Size fixes: "enlarge/shrink N%" or "Nx" → resize op with computed dimensions
 *
 * @param {object} correction - { layer, problem, fix }
 * @param {object} canvas - { w, h } for computing pixel deltas
 * @returns {object|null} - An op like { op:'setStyle', id:..., style:{...} } or null
 */
export function correctionToOp(correction, canvas) {
  if (!correction || !canvas) return null;
  const fix = String(correction.fix || '').toLowerCase();
  const layer = String(correction.layer || '');
  const problem = String(correction.problem || '');

  // We can't resolve layer IDs from just a name — the caller must provide a mapping.
  // Return the correction with enough info for the caller to apply it.
  // The op shape includes a `_correctionHint` so the caller can resolve the target.

  // COLOR fix: extract a target hex
  const hexMatch = fix.match(/#([0-9a-f]{3,8})\b/i);
  if (hexMatch && /(color|colour|contrast|darker|lighter|tint|recolor|set .* to)/i.test(`${problem} ${fix}`)) {
    const hex = fix.match(/#[0-9a-f]{3,8}\b/i)?.[0];
    if (hex) {
      return {
        op: 'setStyle',
        _correctionHint: { layer, problem },
        style: { color: hex },
        _description: `recolor ${layer || 'element'} to ${hex}`,
      };
    }
  }

  // BACKGROUND color fix
  if (hexMatch && /(background|fill|surface|badge|pill|card|button)/i.test(`${problem} ${fix}`)) {
    const hex = fix.match(/#([0-9a-f]{3,8})\b/i)?.[0];
    if (hex) {
      return {
        op: 'setStyle',
        _correctionHint: { layer, problem },
        style: { background: hex },
        _description: `recolor background of ${layer || 'element'} to ${hex}`,
      };
    }
  }

  // POSITION fix: directional nudge
  const posMatch = fix.match(/\b(up|down|left|right)\b[^\d]*(\d{1,2})?\s*%?/);
  if (posMatch && /(position|move|shift|nudge|too (?:high|low|far|close)|misalign)/i.test(problem)) {
    const dir = posMatch[1];
    const pct = posMatch[2] ? Number(posMatch[2]) : 6;
    const dx = dir === 'left' ? -1 : dir === 'right' ? 1 : 0;
    const dy = dir === 'up' ? -1 : dir === 'down' ? 1 : 0;
    return {
      op: 'nudge', // pseudo-op: caller resolves to move
      _correctionHint: { layer, problem },
      dx: dx * (pct / 100) * canvas.w,
      dy: dy * (pct / 100) * canvas.h,
      _description: `nudge ${layer || 'element'} ${dir} ${pct}%`,
    };
  }

  // SIZE fix: scale
  const scaleMatch = fix.match(/(\d(?:\.\d)?)\s*x\b/);
  const growMatch = /\benlarge|\bbigger|\bincrease|\bgrow|\bscale up\b/.test(fix);
  const shrinkMatch = /\bshrink|\bsmaller|\breduce|\bscale down\b/.test(fix);
  if (scaleMatch || growMatch || shrinkMatch) {
    const factor = scaleMatch ? Math.max(0.3, Math.min(3, Number(scaleMatch[1])))
      : growMatch ? 1.25 : 0.8;
    return {
      op: 'scale', // pseudo-op: caller resolves to resize
      _correctionHint: { layer, problem },
      factor,
      _description: `scale ${layer || 'element'} by ${factor}x`,
    };
  }

  // TEXT content fix: the fix text contains the target text
  if (/(text|copy|wording|missing|wrong|should be|set text)/i.test(problem) ||
      /set (?:text|copy|label|headline|title|cta) to/i.test(fix)) {
    const textMatch = fix.match(/["""]([^"""]+)["""]/) || fix.match(/set (?:text|copy|label) to\s+(.+)/i);
    if (textMatch) {
      return {
        op: 'setText',
        _correctionHint: { layer, problem },
        text: textMatch[1].trim(),
        _description: `set text of ${layer || 'element'} to "${textMatch[1].trim().slice(0, 40)}"`,
      };
    }
  }

  // Can't parse a concrete op — return the correction as-is for LLM-mediated resolution
  return {
    op: 'correction',
    _correctionHint: { layer, problem, fix },
    _description: `${layer}: ${problem} → ${fix}`,
  };
}
